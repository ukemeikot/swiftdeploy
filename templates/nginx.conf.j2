pid /tmp/nginx.pid;

events {
    worker_connections 1024;
}

http {
    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    log_format swiftdeploy '$time_iso8601 | $status | ${request_time}s | $upstream_addr | $request';
    access_log /var/log/nginx/access.log swiftdeploy;
    error_log /var/log/nginx/error.log warn;

    proxy_temp_path /tmp/proxy_temp;
    client_body_temp_path /tmp/client_temp;
    fastcgi_temp_path /tmp/fastcgi_temp;
    uwsgi_temp_path /tmp/uwsgi_temp;
    scgi_temp_path /tmp/scgi_temp;

    upstream swiftdeploy_api {
        server api:{{ service.port }};
    }

    server {
        listen 8080;
        server_name _;

        add_header X-Deployed-By swiftdeploy always;

        proxy_connect_timeout {{ nginx.proxy_timeout }}s;
        proxy_send_timeout {{ nginx.proxy_timeout }}s;
        proxy_read_timeout {{ nginx.proxy_timeout }}s;

        location / {
            proxy_pass http://swiftdeploy_api;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_pass_header X-Mode;
        }

        error_page 502 = @error_502;
        error_page 503 = @error_503;
        error_page 504 = @error_504;

        location @error_502 {
            internal;
            default_type application/json;
            return 502 '{"error":"bad gateway","code":"502","service":"swiftdeploy-api","contact":"{{ nginx.contact }}"}';
        }

        location @error_503 {
            internal;
            default_type application/json;
            return 503 '{"error":"service unavailable","code":"503","service":"swiftdeploy-api","contact":"{{ nginx.contact }}"}';
        }

        location @error_504 {
            internal;
            default_type application/json;
            return 504 '{"error":"gateway timeout","code":"504","service":"swiftdeploy-api","contact":"{{ nginx.contact }}"}';
        }
    }
}
